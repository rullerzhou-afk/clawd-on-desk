{
  "name": "clawd-on-desk",
  "version": "0.2.0",
  "description": "A desktop pet that reacts to your Claude Code sessions in real-time.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --mac",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["clawd", "desktop-pet", "electron", "claude-code"],
  "author": "rullerzhou-afk",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.clawd.on-desk",
    "productName": "Clawd on Desk",
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "files": [
      "src/**/*",
      "assets/svg/**/*",
      "assets/tray-icon.png",
      "hooks/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "assets/icon.icns",
        "to": "icon.icns"
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}
